# ─────────────────────────────────────────────────────────────────
# BM-concierge — Production Environment Example
# Copy to .env.production, fill real secrets, NEVER commit secrets.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://ai.4-am.ru
LOG_LEVEL=info

# ── Paths (relative to /app inside container) ─────────────────────
DB_PATH=./data/console.db
SETTINGS_PATH=./data/settings.json

# ── Console UI ────────────────────────────────────────────────────
CONSOLE_ENABLED=true
# Generate: openssl rand -hex 16
CONSOLE_ACCESS_TOKEN=REPLACE_WITH_STRONG_TOKEN

# ── Operator API (Bearer token for Console proxy and CRM) ─────────
# Generate: openssl rand -hex 24
OPERATOR_API_TOKEN=REPLACE_WITH_STRONG_TOKEN

# ── Dev UI (disable in production) ────────────────────────────────
DEV_UI_ENABLED=false

# ── AI Provider ───────────────────────────────────────────────────
# Options: openrouter | deepseek | mock
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=sk-or-v1-REPLACE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat

# DeepSeek (alternative direct provider)
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=sk-REPLACE
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Supabase (leads sync with CRM) ────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_REPLACE
SUPABASE_LEADS_TABLE=leads

# ── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_ENABLED=true
# Options: polling | webhook
TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=1234567890:AAE_REPLACE
TELEGRAM_BOT_URL=https://t.me/your_bot
# Admin Telegram IDs for escalation notifications (comma-separated)
TELEGRAM_ADMIN_IDS=123456789
# Webhook mode (only if TELEGRAM_MODE=webhook)
TELEGRAM_WEBHOOK_URL=https://ai.4-am.ru/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=REPLACE_IF_USED

# ── VK Group ──────────────────────────────────────────────────────
VK_ENABLED=false
VK_GROUP_TOKEN=vk1.a.REPLACE
VK_CONFIRMATION_TOKEN=REPLACE
VK_SECRET_KEY=REPLACE

# ── WebChat widget ────────────────────────────────────────────────
WEBCHAT_ENABLED=true
# Comma-separated allowed origins for CORS
WEBCHAT_ALLOWED_ORIGINS=https://4-am.ru,https://www.4-am.ru,https://ai.4-am.ru

# ── SMTP (admin email notifications) ─────────────────────────────
SMTP_ENABLED=true
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@yandex.ru
SMTP_PASSWORD=REPLACE
SMTP_FROM_NAME=БМ Консьерж
SMTP_FROM_EMAIL=your@yandex.ru
ADMIN_NOTIFICATION_EMAIL=your@yandex.ru
